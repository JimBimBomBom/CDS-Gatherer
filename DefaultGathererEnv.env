# ─────────────────────────────────────────────────────────────────────────────
# CDS-Gatherer default environment
# Override sensitive / deployment-specific values in ProductionGathererEnv.env
# ─────────────────────────────────────────────────────────────────────────────

# How often to run the full Wikidata gather cycle (days).
DATA_GENERATION_INTERVAL_DAYS=30

# Base URL of the cds-app service (used for /languages and /internal/reload).
# Change this if cds-app is exposed under a different name or port.
CDS_APP_BASE_URL=http://cds-app:8080

# Webhook path on cds-app that triggers MySQL + ES reload.
RELOAD_ENDPOINT=/internal/reload

# Seconds to wait for the reload webhook response before giving up.
WEBHOOK_TIMEOUT=30

# Directory inside the container where cities.sql is written.
# Can be overridden at runtime with the --data-dir CLI flag.
DATA_DIR=/app/data

# Seconds to pause between consecutive language fetches (rate-limiting).
LANG_DELAY_SECONDS=10

# Number of consecutive per-language failures before the circuit breaker
# aborts the current gather cycle.
MAX_CONSECUTIVE_LANG_FAILURES=3

# Per-page retry config for transient Wikidata errors (5xx, 429, network timeouts).
# MAX_PAGE_RETRIES: how many times to retry a failing page (0 = no retries).
# RETRY_BASE_DELAY_SECONDS: wait before the first retry; doubles each attempt,
#   capped at 300s (e.g. 30 → 60 → 120 → 300).
MAX_PAGE_RETRIES=3
RETRY_BASE_DELAY_SECONDS=30

# ─────────────────────────────────────────────────────────────────────────────
# Standalone / one-shot usage (CLI flags; not configurable via env)
# ─────────────────────────────────────────────────────────────────────────────
#
# The service supports several CLI flags for running without a live cds-app:
#
#   --once
#       Run a single gather cycle and exit. No scheduler is started.
#       Ideal for bootstrapping an empty database on first deploy.
#
#   --data-dir <path>
#       Write cities.sql to <path> instead of DATA_DIR.
#       Example: --data-dir /mnt/shared/init-data
#
#   --languages en,de,fr
#       Fetch only the listed languages. Skips the cds-app /languages call.
#       Example: --languages en,cs,sk,de,fr,es
#
#   --no-webhook
#       Do not POST a reload notification after writing the SQL file.
#       Use this when running standalone without a running cds-app.
#
# Minimal standalone example (no cds-app required):
#   python scheduler.py --once --data-dir ./data --languages en,de,fr --no-webhook
